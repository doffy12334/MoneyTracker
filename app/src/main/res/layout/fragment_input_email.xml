<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_background">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_arrow_back"
        app:tint="@color/primary_color" />

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/money_tracker"
        android:textColor="@color/primary_color"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBack" />

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="30dp"
        android:backgroundTint="@color/primary_color"
        android:text="XД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВћГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўвЂљВ¬Г‚ВљД‚вЂљГ‚В¬Г„вЂљГўв‚¬ВљД‚вЂљГ‚ВћГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚ВўД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚В¬Д‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВћГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўвЂљВ¬Г‚ВљД‚вЂљГ‚В¬Г„вЂљГўв‚¬ВљД‚вЂљГ‚ВљГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚ВЎc nhГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВћД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўвЂљВ¬Г‚ВљД‚вЂљГ‚В¬Г„вЂљГўв‚¬ВљД‚вЂљГ‚ВљГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚ВЎД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВћГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўвЂљВ¬Г‚ВљД‚вЂљГ‚В¬Г„вЂљГўв‚¬ВљД‚вЂљГ‚ВљГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚ВєД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВћГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚вЂљГ‚ВўГ„вЂљГ‚ВўД‚ВўГўвЂљВ¬Г‚ВљД‚вЂљГ‚В¬Г„вЂљГўв‚¬ВљД‚вЂљГ‚ВљГ„вЂљГўв‚¬ВћД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГ‚ВўД‚ВўГўв‚¬ВљГ‚В¬Д‚вЂљГ‚ВљД‚вЂћГўв‚¬ВљД‚ВўГўвЂљВ¬Г‚ВљГ„вЂљГўв‚¬ВљД‚вЂљГ‚В­n"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_arrow_right"
        app:iconGravity="textEnd"
        app:iconTint="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@+id/etEmail" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnConfirm" />


    <!-- Icon Area -->
    <View
        android:id="@+id/iconBackground"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/circle_dashed_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvAppTitle" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_mail"
        app:layout_constraintBottom_toBottomOf="@+id/iconBackground"
        app:layout_constraintEnd_toEndOf="@+id/iconBackground"
        app:layout_constraintStart_toStartOf="@+id/iconBackground"
        app:layout_constraintTop_toTopOf="@+id/iconBackground" />

    <!-- Text Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="@string/input_email"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iconBackground" />


    <EditText
        android:id="@+id/etEmail"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_input_field"
        android:hint="@string/email"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <!-- Help Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/helpCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/surface_variant"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent">
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>

