<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8FF"
    android:padding="24dp">

    <!-- Tiêu đề màn hình -->
    <TextView
        android:id="@+id/tvReportsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spending Reports"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#131B2E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvReportsSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Analyze your expenses by category."
        android:textColor="#8E8E93"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvReportsTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Thanh Filter Week/Month/Year -->
    <LinearLayout
        android:id="@+id/llFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_search_bar"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvReportsSubTitle">

        <TextView
            android:id="@+id/tvFilterWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Week"
            android:textColor="#8E8E93"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/tvFilterMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_report_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Month"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFilterYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Year"
            android:textColor="#8E8E93"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Card chứa Biểu đồ tròn (Donut Chart) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@id/llFilter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL SPENDING"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_gravity="start"/>

            <!-- Sử dụng MPAndroidChart thay cho ProgressBar -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/spendingPieChart"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Danh sách chi tiết phía dưới biểu đồ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBreakdown"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardChart"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>