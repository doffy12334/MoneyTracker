    <!-- Thanh Filter Week/Month/Year -->
    <LinearLayout
        android:id="@+id/llFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_search_bar"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvReportsSubTitle">

        <TextView
            android:id="@+id/tvFilterWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Week"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_filter_inactive" />

        <TextView
            android:id="@+id/tvFilterMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Month"
            android:textColor="@color/inverse_text"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFilterYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Year"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_filter_inactive" />
    </LinearLayout>

