<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/budget_item_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/budget_item_surface">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivCatIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_blue_soft"
                android:padding="12dp"
                app:tint="@color/info_color" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/ivCatIcon"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvBudgetName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_food"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvBudgetLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/budget_limit_preview"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnDeleteBudget"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_delete_button"
                android:padding="7dp"
                android:scaleType="center"
                android:src="@drawable/ic_trash_red_bold" />

            <TextView
                android:id="@+id/tvBudgetPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="44dp"
                android:text="@string/budget_percent_preview"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/info_color"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/pbBudget"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="16dp"
            android:progressBackgroundTint="@color/budget_progress_track"
            android:progressTint="@color/info_color"
            android:progress="80" />

        <TextView
            android:id="@+id/tvSpentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/budget_spent_preview"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
