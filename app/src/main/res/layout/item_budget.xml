<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#99F0FDF4">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivCatIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_primary"
                android:padding="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/ivCatIcon"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvBudgetName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ăn uống"
                    android:textStyle="bold"
                    android:textColor="#131B2E" />

                <TextView
                    android:id="@+id/tvBudgetLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới hạn: 5.000.000đ"
                    android:textSize="12sp"
                    android:textColor="#6D7B6D" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBudgetPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#006D36"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/pbBudget"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="16dp"
            android:progress="80" />

        <TextView
            android:id="@+id/tvSpentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đã tiêu: 4.000.000đ"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:textColor="#3D4A3E" />

    </LinearLayout>
</androidx.cardview.widget.CardView>